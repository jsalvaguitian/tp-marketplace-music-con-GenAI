@using System.Security.Claims
@inject Servicios.IConversacionService ConversacionService
@{
    var chatsRecientes = new List<Entidades.Conversacion>();
    var uid = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        uid = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
        try
        {
            chatsRecientes = (await ConversacionService.ObtenerConversacionesUsuarioAsync(uid))
                .OrderByDescending(c => c.Id)
                .Take(5)
                .ToList();
        }
        catch { }
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChatRealTime</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-broadcast"></i> ChatRealTime
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMenu">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Publicacion" asp-action="Index">Publicaciones</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown" id="notifDropdownContainer">
                                <a class="nav-link position-relative px-2" href="#" role="button" data-bs-toggle="dropdown" title="Notificaciones">
                                    <i class="bi bi-bell fs-5"></i>
                                    <span class="position-absolute badge rounded-pill bg-danger" style="font-size: 0.55rem; top: 4px; right: -2px; display: none;" id="notifBadge">0</span>
                                </a>

                                <div class="dropdown-menu dropdown-menu-end p-2" style="min-width:320px;max-height:400px;overflow-y:auto;" id="notifDropdown">
                                    <h6 class="dropdown-header">Notificaciones</h6>
                                    <div id="notifList">
                                        <p class="text-muted small mb-0 text-center py-3" id="sinNotif">Sin notificaciones</p>
                                    </div>
                                </div>
                            </li>
                            <li class="nav-item dropdown" id="chatDropdownContainer">
                                <a class="nav-link px-2" href="#" role="button" data-bs-toggle="dropdown" title="Chats activos">
                                    <i class="bi bi-chat-dots fs-5"></i>
                                </a>

                                <div class="dropdown-menu dropdown-menu-end p-2" style="min-width:320px;max-height:400px;overflow-y:auto;" id="chatDropdownMenu">
                                    <h6 class="dropdown-header">Tus conversaciones</h6>
                                    @if (chatsRecientes.Any())
                                    {
                                        foreach (var c in chatsRecientes)
                                        {
                                            var otroNombre = c.VendedorId == uid
                                                ? $"{c.Comprador?.Nombre} {c.Comprador?.Apellido}"
                                                : $"{c.Vendedor?.Nombre} {c.Vendedor?.Apellido}";
                                            <a asp-controller="Chat" asp-action="Conversacion" asp-route-id="@c.Id" class="dropdown-item border-bottom py-2">
                                                <div class="d-flex align-items-center">
                                                    <div class="flex-shrink-0">
                                                        <i class="bi bi-person-circle fs-4 me-2 text-secondary"></i>
                                                    </div>
                                                    <div class="flex-grow-1 text-truncate">
                                                        <strong class="d-block text-truncate small">@c.Publicacion.Titulo</strong>
                                                        <small class="text-muted text-truncate">@otroNombre</small>
                                                    </div>
                                                </div>
                                            </a>
                                        }
                                        <div class="text-center mt-2">
                                            <a asp-controller="Chat" asp-action="Index" class="btn btn-sm btn-outline-primary w-100">Ver todas</a>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted small mb-0 text-center py-3">Sin conversaciones activas</p>
                                    }
                                </div>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light py-1 px-2 small fw-semibold" asp-controller="Usuario" asp-action="Perfil">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Cuenta" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm ms-1">Salir</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm me-2" asp-controller="Cuenta" asp-action="Login">Iniciar sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm" asp-controller="Cuenta" asp-action="Registro">Registrarse</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-fill">
        @if (TempData["MensajeExito"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["MensajeExito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1">&copy; @DateTime.Now.Year - ChatRealTime</p>
            <p class="mb-0 text-secondary small">
                Proyecto académico — Real Time Communication con SignalR · ASP.NET Core MVC
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/js/notificaciones.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
