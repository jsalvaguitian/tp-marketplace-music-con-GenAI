@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center">
    <i class="bi bi-exclamation-triangle-fill text-danger display-1"></i>
    <h1 class="mt-3">Ocurrió un error</h1>
    <p class="text-muted">Algo salió mal procesando tu solicitud.</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
</div>