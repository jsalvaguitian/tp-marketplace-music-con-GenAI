@model Entidades.Publicacion
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Crear Publicación";
}

<div class="container mt-3">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Crear Publicación</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Crear" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Titulo" class="form-label fw-bold">Título</label>
                            <input asp-for="Titulo" class="form-control" placeholder="Ingresá el título..." />
                            <span asp-validation-for="Titulo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Detallá el artículo..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Imagen</label>
                                <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Categoría</label>
                                <select name="categoria" class="form-select" required>
                                    <option value="0">-- Seleccioná una categoría --</option>
                                    @foreach (var cat in ViewBag.Categorias)
                                    {
                                        <option value="@cat.Value">@cat.Text</option>
                                    }
                                </select>
                                <span class="text-danger">@Html.ValidationMessage("Categoria")</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="FechaCierre" class="form-label fw-bold">Fecha de cierre</label>
                            <input asp-for="FechaCierre" type="date" class="form-control" min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" style="max-width: 200px;" />
                            <span asp-validation-for="FechaCierre" class="text-danger"></span>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Volver atrás</a>
                            <button type="submit" class="btn btn-success">Guardar publicación</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}