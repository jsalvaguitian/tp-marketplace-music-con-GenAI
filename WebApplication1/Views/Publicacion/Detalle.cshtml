@model Entidades.Publicacion
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Titulo;
    var esPropietario = User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.UsuarioId.ToString();
}

<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Volver al listado
            </a>
        </div>
    </div>

    <div class="row">

        <!-- Imagen -->
        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm border-0">
                <img src="@Model.ImagenUrl"
                     class="card-img-top"
                     alt="@Model.Titulo"
                     style="height:420px;object-fit:cover;" />
            </div>
        </div>

        <!-- Información -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">

                    <div class="d-flex justify-content-between">
                        <span class="badge bg-primary">@Model.Categoria</span>
                        <span class="badge bg-secondary">@Model.Estado</span>
                    </div>

                    @if (Model.Estado == Enums.EstadoPublicacion.Finalizada)
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            <i class="bi bi-exclamation-circle"></i>
                            <strong>Publicación finalizada</strong>
                            <p class="mb-0 mt-2">Esta publicación ha sido cerrada por su creador y ya no acepta nuevas ofertas.</p>
                        </div>
                    }

                    <h2 class="mt-3 fw-bold">@Model.Titulo</h2>

                    <hr />

                    <h5>Descripción</h5>
                    <p class="text-muted">@Model.Descripcion</p>

                    @if (Model.Estado == Enums.EstadoPublicacion.Activa)
                    {
                        <div class="alert alert-warning mt-4">
                            <strong>
                                <i class="bi bi-clock"></i>
                                Cierra el:
                            </strong>
                            @Model.FechaCierre.ToString("dd/MM/yyyy")
                        </div>
                    }

                    <div class="mt-4">
                        <h6 class="text-muted">Publicado por</h6>
                        <h5>
                            <a asp-controller="Usuario" asp-action="Perfil" asp-route-id="@Model.UsuarioId" class="text-decoration-none text-dark fw-bold">
                                <i class="bi bi-person-circle text-primary"></i>
                                @Model.Usuario?.Nombre @Model.Usuario?.Apellido
                            </a>
                        </h5>
                    </div>


                    <hr />

                    @if (esPropietario && Model.Estado == Enums.EstadoPublicacion.Activa)
                    {
                        <div class="d-grid gap-2">
                            <a asp-action="Editar"
                               asp-route-id="@Model.Id"
                               class="btn btn-primary">
                                <i class="bi bi-pencil-square"></i>
                                Editar publicación
                            </a>
                            <form asp-action="Cerrar" asp-route-id="@Model.Id" method="post" style="margin:0;">
                                <button type="submit" class="btn btn-danger w-100"
                                        onclick="return confirm('¿Estás seguro de que deseas cerrar esta publicación? No podrás reabrirla.');">
                                    <i class="bi bi-x-circle"></i>
                                    Cerrar publicación
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">
                        <i class="bi bi-info-circle"></i>
                        Información de la publicación
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Estado</strong>
                            <p>@Model.Estado</p>
                        </div>
                        <div class="col-md-4">
                            <strong>Categoría</strong>
                            <p>@Model.Categoria</p>
                        </div>
                        <div class="col-md-4">
                            <strong>Fecha de cierre</strong>
                            <p>@Model.FechaCierre.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Estado == Enums.EstadoPublicacion.Activa)
    {
        <!-- Bandeja de Ofertas en Tiempo Real -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="bi bi-hand-index"></i> Bandeja de Ofertas
                        </h4>
                        <small class="text-muted" id="contadorOfertas">0 ofertas</small>
                    </div>
                    <div class="card-body" style="height:320px;overflow-y:auto;"
                         id="listaOfertas"
                         data-publicacion-id="@Model.Id"
                         data-es-propietario="@esPropietario.ToString().ToLower()"
                         data-dueno-id="@Model.UsuarioId">
                        @{
                            var ofertasExistentes = Model.Ofertas?.OrderBy(o => o.FechaCreacion).ToList();
                        }
                        @if (ofertasExistentes != null && ofertasExistentes.Any())
                        {
                            foreach (var oferta in ofertasExistentes)
                            {
                                <div class="mb-3 p-3 border rounded oferta-item" data-id="@oferta.Id">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>@($"{oferta.Usuario?.Nombre} {oferta.Usuario?.Apellido}")</strong>
                                            <small class="text-muted">@oferta.FechaCreacion.ToString("dd/MM HH:mm")</small>
                                            <p class="mb-1 mt-1">@oferta.Mensaje</p>
                                        </div>
                                        @if (esPropietario && oferta.UsuarioId != Model.UsuarioId)
                                        {
                                            <a href="/Chat/AceptarOferta?publicacionId=@Model.Id&ofertanteId=@oferta.UsuarioId"
                                               class="btn btn-sm btn-outline-success ms-2">
                                                <i class="bi bi-chat-dots"></i> Negociar
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted text-center" id="sinOfertas">Aún no hay ofertas. Sé el primero en ofertar.</p>
                        }
                    </div>
                    @if (!esPropietario)
                    {
                        <div class="card-footer">
                            <div class="input-group">
                                <input type="text" id="mensajeOferta" class="form-control" placeholder="Escribí tu oferta..." maxlength="500" autocomplete="off" />
                                <button class="btn btn-primary" id="btnEnviarOferta">
                                    <i class="bi bi-send"></i> Enviar oferta
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @section Scripts {
            <script src="~/js/ofertas.js" asp-append-version="true"></script>
        }
    }

</div>