@model IEnumerable<Entidades.Publicacion>

@{
    ViewData["Title"] = "Publicaciones";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-collection-play me-2"></i>Últimas Publicaciones</h2>
        <a asp-action="Crear" class="btn btn-primary shadow-sm fw-bold">
            <i class="bi bi-plus-lg me-1"></i> Nueva Publicación
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center rounded-4 shadow-sm py-5 border">
            <i class="bi bi-inbox fs-1 d-block mb-3 text-muted"></i>
            <h4 class="fw-bold text-secondary">No hay publicaciones todavía</h4>
            <p class="text-muted">Sé el primero en publicar un artículo.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <div class="position-relative">
                            <img src="@item.ImagenUrl" class="card-img-top object-fit-cover" alt="@item.Titulo" style="height: 220px;">
                            <div class="position-absolute top-0 end-0 p-2">
                                <span class="badge bg-dark bg-opacity-75 rounded-pill shadow-sm">@item.Estado</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">
                                    <i class="bi bi-tag-fill me-1"></i> @item.Categoria
                                </span>
                            </div>
                            <h5 class="card-title fw-bold">@item.Titulo</h5>
                            <p class="card-text text-muted small text-truncate mb-4">@item.Descripcion</p>
                            
                            <div class="mt-auto">
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-outline-dark w-100 rounded-3 fw-semibold">
                                    Ver detalles
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>